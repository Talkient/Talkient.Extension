{
  "manifest_version": 3,
  "name": "Talkient",
  "description": "Talkient: Your best Text-To-Speech extension!",
  "icons": {
    "48": "assets/png/text-to-speech.png",
    "128": "assets/png/text-to-speech.png"
  },
  "version": "0.0.11",
  "permissions": ["tts", "storage", "contextMenus"],
  "action": {
    "default_popup": "./popup/popup.html"
  },
  "background": {
    "service_worker": "./background/service-worker.js",
    "type": "module"
  },
  "options_page": "./options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["./content/content.css"],
      "js": ["./content/content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/svg/*.svg"],
      "matches": ["<all_urls>"]
    }
  ]
}

{
  "permissions": {
    "allow": [
      "Bash(ls)",
      "Bash(pwd)",
      "Bash(cat)",
      "Bash(grep)",
      "Bash(find)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log)",
      "Bash(dir)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run lint:fix:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm test:e2e:*)",
      "Bash(pnpm test:all:*)",
      "Bash(pnpm outdated:*)",
      "Bash(pnpm update:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm build)",
      "Bash(git rm *)",
      "Bash(git add *)",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__click",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__list_console_messages",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__new_page"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(env)",
      "Bash(printenv)",
      "Read(.env*)",
      "Read(.claude/settings.local.json)",
      "Read(//etc/passwd)",
      "Read(~/.ssh/**)",
      "Write(//etc/**)",
      "Write(~/.ssh/**)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "chrome-devtools"
  ]
}

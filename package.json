{
  "name": "Talkient.Extension",
  "version": "0.0.18",
  "description": "Talkient Extension",
  "main": "index.js",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"e2e/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"e2e/**/*.ts\"",
    "publish": "rm -rf dist && pnpm build && pnpm update-manifest && pnpm update-assets && pnpm update-htmls && pnpm update-css && rm -rf dist/features && rm -rf dist/shared && rm -f dist/background/tab-manager.js && rm -f dist/content/highlight.js && rm -f dist/tsconfig.tsbuildinfo",
    "build": "tsc --build && pnpm build:content && pnpm build:popup && pnpm build:sw && pnpm build:options",
    "update-manifest": "cp manifest.json dist/",
    "update-assets": "cp assets/ dist/ -r",
    "update-htmls": "cp src/features/settings/options/*.html dist/options -r && cp src/popup/*.html dist/popup -r",
    "update-css": "cp src/features/settings/options/*.css dist/options -r && cp src/popup/*.css dist/popup -r && cp src/content/*.css dist/content -r",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build:content": "esbuild src/content/content.ts --bundle --outfile=dist/content/content.js --format=iife --platform=browser --target=chrome58",
    "build:popup": "esbuild src/popup/popup.ts --bundle --outfile=dist/popup/popup.js --format=iife --platform=browser --target=chrome58",
    "build:sw": "esbuild src/background/service-worker.ts --bundle --outfile=dist/background/service-worker.js --format=esm --platform=browser --target=chrome58",
    "build:options": "esbuild src/features/settings/options/options-ui.ts --bundle --outfile=dist/options/options.js --format=iife --platform=browser --target=chrome58",
    "test:e2e": "pnpm run publish && playwright test --reporter=list",
    "test:e2e:ui-report": "pnpm run publish && playwright test",
    "test:e2e:ui": "pnpm run publish && playwright test --ui",
    "test:e2e:debug": "pnpm run publish && playwright test --debug",
    "test:e2e:headless": "set CI=true && pnpm test:e2e",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "Talkient Extension Contributors",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=20.19.0 <21 || >=22.13.0 <23 || >=24.0.0"
  },
  "packageManager": "pnpm@10.11.0",
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.1.37",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.3.4",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
